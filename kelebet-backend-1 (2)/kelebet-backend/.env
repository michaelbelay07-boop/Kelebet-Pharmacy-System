# ── SERVER ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── DATABASE ─────────────────────────────────────
# Get this from Railway or any PostgreSQL provider
DATABASE_URL="postgresql://postgres:michael1993@localhost:5432/Kelebet_db"
# ── JWT AUTH ──────────────────────────────────────
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── CLOUDINARY (for prescription image uploads) ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── EMAIL (for order confirmations) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── CHAPA PAYMENT (Ethiopian payment gateway) ────
CHAPA_SECRET_KEY=CHASECK_TEST-your_key_here
CHAPA_BASE_URL=https://api.chapa.co/v1

# ── FRONTEND URL (for CORS) ───────────────────────
CLIENT_URL=http://localhost:3000
